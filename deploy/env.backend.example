# Copy to deploy/.env on the home server (never commit deploy/.env).

SWIFTTRADE_BACKEND_IMAGE=veski4a06/swifttrade-backend:latest
BACKEND_HOST_PORT=8010

# Supabase (same project as the web portal)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Public URL of this backend (used in logs / links)
APP_BASE_URL=https://signals.swifttrade.app

# MVP production: licensing uses Supabase only — no local Postgres required.
RUN_DB_MIGRATIONS=false

# Strategy runner (Mode 1 — broadcasts signals over WS to the desktop app).
# Desktop app must be connected to actually place orders.
# Keep OFF if you are using the live_trader service (Mode 2) instead.
RUN_STRATEGY=false

# Core signals per cycle delivered to Starter (and Pro). Position caps (trial/starter=3, pro=10)
# are set in backend/app/services/tiers.py and enforced in the desktop app — not this variable.
# STARTER_CORE_SIGNALS=2

# ── Owner executor (Mode 2) — trades YOUR personal account with MOMENTUM ──────
# The owner executor now runs the validated cross-sectional MOMENTUM strategy
# (top-8 strongest global stocks, equal-weight, monthly rebalance, cash in
# risk-off; 14y walk-forward: ~+27.7%/yr, Sharpe 1.19). It is independent of the
# customer signal feed (RUN_STRATEGY) — you can run either or both.
#
# PAPER vs LIVE is controlled ENTIRELY by these two vars. T212 demo and live use
# DIFFERENT hostnames AND different API keys, so going live = change BOTH:
#   PAPER:  OWNER_T212_API_KEY=<demo key>   OWNER_T212_BASE_URL=https://demo.trading212.com
#   LIVE :  OWNER_T212_API_KEY=<live key>   OWNER_T212_BASE_URL=https://live.trading212.com
OWNER_EXECUTOR_ENABLED=true
OWNER_T212_API_KEY=
OWNER_T212_BASE_URL=https://demo.trading212.com
# First run safety: compute + log the rebalance but place NO orders. Set false to trade.
OWNER_DRY_RUN=true
# How often to wake and check the monthly-rebalance gate (seconds). Default 6h.
# OWNER_CHECK_INTERVAL_S=21600

# Daily market data for the momentum strategy (Twelve Data). REQUIRED for the owner executor.
TWELVEDATA_API_KEY=

# ── Legacy autonomous live trader (old ML bot) ────────────────────────────────
# Only used by the separate `live_trader` Docker service (profile: trader).
# The owner executor above REPLACES this for personal trading. Leave blank unless
# you specifically run that legacy service. DO NOT set RUN_STRATEGY=true with it.
T212_API_KEY=
T212_SECRET_KEY=
T212_BASE_URL=https://demo.trading212.com

# ── Position sizing / concentration ──────────────────────────────────────────
# PROD_POS_CEILING = the hard cap on how much of the account ONE position may
# take, after the bull/bear risk multiplier (4.2x in a bull regime). 0.90 is the
# max-profit setting (~28% OOS return / -11.3% DD) but allows ~90% in ONE stock
# — high single-stock gap risk. Lower to 0.25 (~38% per name, -4.4% DD) or 0.20
# (risk-adjusted optimum) to de-risk. Sweep: `python -m t212_miner_bot.sim_position_cap`.
PROD_POS_CEILING=0.90
PROD_RISK_CEILING=0.75

# Optional: Telegram alerts on every trade (buy/exit).
# Create a bot with @BotFather, get the chat ID from @userinfobot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Debug test signals — off on the public internet.
DEBUG_ROUTES_ENABLED=false
# DEBUG_API_KEY=change-me-if-you-enable-debug

# Optional legacy JWT fields (unused for Supabase licensing)
JWT_SECRET=change-me-long-random
JWT_ISSUER=swifttrade-backend
JWT_AUDIENCE=swifttrade-portal
