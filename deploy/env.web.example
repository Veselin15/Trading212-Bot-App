# Copy to deploy/.env.web when using `docker compose --profile web up -d`
# For Cloudflare Pages, set these in the Pages dashboard instead.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Two paid tiers — one recurring Stripe Price each.
STRIPE_PRICE_ID_STARTER=price_...   # €19/mo Starter
STRIPE_PRICE_ID_PRO=price_...       # €49/mo Pro
# Legacy single-price fallback (used as Pro if STRIPE_PRICE_ID_PRO is unset).
STRIPE_PRICE_ID=price_...

NEXT_PUBLIC_SITE_URL=https://swifttrade.app
STRIPE_CUSTOMER_PORTAL_RETURN_URL=https://swifttrade.app/dashboard

DESKTOP_DOWNLOAD_URL=https://github.com/YOUR_ORG/YOUR_REPO/releases/download/v1.0.0/SwiftTrade.exe
DESKTOP_APP_VERSION=1.0.0
DESKTOP_SIGNAL_SERVER_URL=wss://signals.swifttrade.app/ws/exec

# Trial email drip (Phase 5 — optional). Drip is a no-op until RESEND_API_KEY + EMAIL_FROM are set.
# Point a daily scheduler (Cloudflare Cron / Vercel Cron / GitHub Action) at
#   POST https://swifttrade.app/api/cron/trial-emails   with header  x-cron-secret: <CRON_SECRET>
# RESEND_API_KEY=re_...
# EMAIL_FROM=SwiftTrade <noreply@swifttrade.app>
# CRON_SECRET=long-random-string
